# ==============================================================================
# Local developer settings
# ==============================================================================
# Copy this file to `.env` before running Docker Compose or Makefile targets that
# rely on local environment variables.
#
# Use `[replace_me]` placeholders for sensitive or user-specific values. Do not
# commit a populated `.env` file.

# ==============================================================================
# Repository and DVC local setup
# ==============================================================================
# Used by: make repo_setup
GIT_USER="[replace_me]"
GIT_EMAIL="[replace_me]"

# Used by: make dvc-setup to populate .dvc/config.local.
# These values authenticate the DVC S3 remote hosted by DagsHub.
DAGSHUB_ACCESS_KEY_ID="[replace_me]"
DAGSHUB_SECRET_ACCESS_KEY="[replace_me]"

# ==============================================================================
# Runtime host ports
# ==============================================================================
# Business apps / application APIs: 10000-10999.
API_HOST_PORT=10000

# Orchestration / workflow tools: 12000-12999.
AIRFLOW_HOST_PORT=12080
AIRFLOW_FLOWER_HOST_PORT=12555

# Tracking and artifact systems: 13000-13999.
MINIO_API_HOST_PORT=13000
MLFLOW_HOST_PORT=13001
MINIO_CONSOLE_HOST_PORT=13002

# Observability and alerting: 14000-14999.
PROMETHEUS_HOST_PORT=14090
PUSHGATEWAY_HOST_PORT=14091
CADVISOR_HOST_PORT=14200
GRAFANA_HOST_PORT=14300
ALERTMANAGER_HOST_PORT=14093

# Dev-only helpers and local debug tools: 15000-15999.
MAILHOG_SMTP_HOST_PORT=15025
MAILHOG_UI_HOST_PORT=15080

# ==============================================================================
# Runtime images
# ==============================================================================
# Keep readable tags for local developer tooling. Validated digests are tracked in
# docs/dependency-strategy.md and can be used for stronger production hardening.
AIRFLOW_IMAGE_NAME="apache/airflow:3.2.2-python3.12"
AIRFLOW_POSTGRES_IMAGE="postgres:16"
MLFLOW_IMAGE="ghcr.io/mlflow/mlflow:v3.13.0-full"
MLFLOW_POSTGRES_IMAGE="postgres:16"
MINIO_IMAGE="minio/minio:RELEASE.2025-09-07T16-13-09Z"
MINIO_MC_IMAGE="minio/mc:RELEASE.2025-08-13T08-35-41Z"
PROMETHEUS_IMAGE="prom/prometheus:v3.12.0"
GRAFANA_IMAGE="grafana/grafana:13.0.1-security-01"

# ==============================================================================
# Makefile defaults
# ==============================================================================
# Used by: make start/stop/logs/sim_api_req
PROFILE="ptf"
SERVICE="api-dev"
URL="http://localhost:${API_HOST_PORT}"
N=100
P_OK=0.80
API_USER="user1"
API_PASS="user1"
LIMIT=10
OFFSET=0
COUNTER_IDS="Sebastopol_N-S_airflow_day0,Sebastopol_S-N_airflow_day0"

# ==============================================================================
# ML pipeline parameters
# ==============================================================================
# Ingestion: src/ml/ingest/import_raw_data.py
RAW_FILE_NAME="comptage-velo-donnees-compteurs-2024-2025_Enriched_ML-ready_data.csv"
SITE="Totem 73 boulevard de Sébastopol"
ORIENTATION="N-S"
RANGE_START=0.0
RANGE_END=75.0
SUB_DIR="Sebastopol_N-S"
INTERIM_NAME="initial.csv"

# Features: src/ml/features/build_features.py
PROCESSED_NAME="initial_with_feats.csv"

# Modeling: src/ml/models/train_and_predict.py
AR=7
MM=1
ROLL=24
TEST_RATIO=0.25
GRID_ITER=0

# ==============================================================================
# API runtime configuration
# ==============================================================================
DATA_FINAL_ROOT="/app/data/final"

# ==============================================================================
# MLflow target variables
# ==============================================================================
# These variables are consumed by runtime code. Do not edit them directly for a
# mode switch. Use one of the mirrored presets below through make env-compose,
# make env-dagshub, or make env-local.
MLFLOW_TRACKING_URI="http://mlflow-server:5000"
MLFLOW_S3_ENDPOINT_URL="http://mlflow-minio:9000"
MLFLOW_TRACKING_USERNAME="[replace_me]"
MLFLOW_TRACKING_PASSWORD="[replace_me]"
AWS_ACCESS_KEY_ID="minio"
AWS_SECRET_ACCESS_KEY="[replace_me]"
AWS_DEFAULT_REGION="us-east-1"

# ==============================================================================
# MLflow Compose preset
# ==============================================================================
# Internal Docker Compose mode: MLflow server and MinIO are reached through Docker
# service names. This preset is used by make ops, make rebuild_full, and mlops-*.
MLFLOW_TRACKING_URI_COMPOSE="http://mlflow-server:5000"
MLFLOW_S3_ENDPOINT_URL_COMPOSE="http://mlflow-minio:9000"
MLFLOW_TRACKING_USERNAME_COMPOSE=""
MLFLOW_TRACKING_PASSWORD_COMPOSE=""
AWS_ACCESS_KEY_ID_COMPOSE="minio"
AWS_SECRET_ACCESS_KEY_COMPOSE="[replace_me]"
AWS_DEFAULT_REGION_COMPOSE="us-east-1"

# ==============================================================================
# MLflow DagsHub preset
# ==============================================================================
# Remote DagsHub mode: no S3 endpoint and no AWS credentials should be exported.
MLFLOW_TRACKING_URI_DAGSHUB="https://dagshub.com/zheddhe/avr25-mle-trafic-cycliste.mlflow"
MLFLOW_S3_ENDPOINT_URL_DAGSHUB=""
MLFLOW_TRACKING_USERNAME_DAGSHUB="[replace_me]"
MLFLOW_TRACKING_PASSWORD_DAGSHUB="[replace_me]"
AWS_ACCESS_KEY_ID_DAGSHUB=""
AWS_SECRET_ACCESS_KEY_DAGSHUB=""
AWS_DEFAULT_REGION_DAGSHUB=""

# ==============================================================================
# MLflow local backend preset
# ==============================================================================
# Local backend mode: no MLFLOW_* target variable and no AWS target variable should
# be exported. MLflow then falls back to ./mlruns or to the explicit local server
# started by make mlflow-local.
MLFLOW_TRACKING_URI_LOCAL=""
MLFLOW_S3_ENDPOINT_URL_LOCAL=""
MLFLOW_TRACKING_USERNAME_LOCAL=""
MLFLOW_TRACKING_PASSWORD_LOCAL=""
AWS_ACCESS_KEY_ID_LOCAL=""
AWS_SECRET_ACCESS_KEY_LOCAL=""
AWS_DEFAULT_REGION_LOCAL=""

# ==============================================================================
# MLflow server and artifact storage configuration
# ==============================================================================
# Host header allow-list used by MLflow 3 security middleware.
# It must support Docker service calls and local browser access through WSL.
MLFLOW_SERVER_ALLOWED_HOSTS="localhost,localhost:*,127.0.0.1,127.0.0.1:*,mlflow-server,mlflow-server:5000,172.16.*,172.17.*,172.18.*,172.19.*,172.20.*,172.21.*,172.22.*,172.23.*,172.24.*,172.25.*,172.26.*,172.27.*,172.28.*,172.29.*,172.30.*,172.31.*,192.168.*,10.*"
MLFLOW_POSTGRES_USER="mlflow"
MLFLOW_POSTGRES_PASSWORD="[replace_me]"
MLFLOW_POSTGRES_DB="mlflow"
MINIO_ROOT_USER="minio"
MINIO_ROOT_PASSWORD="[replace_me]"

# ==============================================================================
# Airflow runtime configuration
# ==============================================================================
# AIRFLOW_UID usually matches: id -u
# AIRFLOW_GID usually matches: getent group docker | cut -d: -f3
AIRFLOW_UID=1000
AIRFLOW_GID=1001
AIRFLOW_FERNET_KEY="[replace_me]"
# Shared by scheduler, workers, and API server for Airflow execution API JWTs.
# Use a long random value, preferably at least 64 bytes.
AIRFLOW_API_AUTH_JWT_SECRET="[replace_me]"
AIRFLOW_POSTGRES_USER="airflow"
AIRFLOW_POSTGRES_PASSWORD="[replace_me]"
AIRFLOW_POSTGRES_DB="airflow"

# ==============================================================================
# Monitoring runtime configuration
# ==============================================================================
GRAFANA_ADMIN_USER="grafana"
GRAFANA_ADMIN_PASSWORD="[replace_me]"
PUSHGATEWAY_ADDR="monitoring-pushgateway:9091"
# Keep metric push disabled by default for safe local commands and tests.
# Set to 0 only when the Pushgateway service is available and should receive
# metrics from ML/API pipeline code.
DISABLE_METRICS_PUSH=1

# ==============================================================================
# Miscellaneous
# ==============================================================================
# Time zone used for local conversions.
TZ="Europe/Paris"
